// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id                String  @id @default(uuid())
  name              String  @unique // ADMIN, USER, OPERATOR
  canViewUsers      Boolean @default(false)
  canCreateUsers    Boolean @default(false)
  canEditUsers      Boolean @default(false)
  canDeleteUsers    Boolean @default(false)
  canViewLogs       Boolean @default(false)
  canManageSettings Boolean @default(false)
  users             User[]
}

model Status {
  id    String @id @default(uuid())
  name  String @unique // ACTIVE, NOT_ACTIVE, SUSPEND
  users User[]
}
model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  password       String
  roleId         String
  role           Role      @relation(fields: [roleId], references: [id])
  statusId       String
  status         Status    @relation(fields: [statusId], references: [id])
  avatar         String?   // Field for profile picture path
  isActive       Boolean   @default(true) // User status: Active or Not Active
  deviceInfo     String?   // Stored parsed device info (Browser, OS, Type)
  lastLogin      DateTime? // Field for tracking last login time
  lastActivity   DateTime? // Field for tracking real-time activity status
  lastSessionId  String?   // To enforce one session per user
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  AuthLog        AuthLog[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content     String   
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}


model AuthLog {
  id             String   @id @default(uuid())
  userId         String?
  usernameInput  String   // The email/username entered by user
  eventType      String   // LOGIN_SUCCESS, LOGIN_FAILED, LOGOUT
  failureReason  String?  // WRONG_PASSWORD, USER_NOT_FOUND, ACCOUNT_INACTIVE
  ipAddress      String
  userAgent      String   
  deviceType     String
  browser        String
  os             String
  deviceId       String?  // Fingerprint hash
  isp            String?  // Internet Service Provider
  country        String?  // Country of origin
  isNewDevice    Boolean  @default(false)
  isSuspicious   Boolean  @default(false)
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([usernameInput])
  @@index([ipAddress])
  @@index([createdAt])
}
