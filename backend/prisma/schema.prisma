// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER") // USER or ADMIN
  avatar    String?  // Field for profile picture path
  isActive  Boolean  @default(true) // User status: Active or Not Active
  deviceInfo String? // Stored parsed device info (Browser, OS, Type)
  lastLogin DateTime? // Field for tracking last login time
  lastSessionId String? // To enforce one session per user
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  AuthLog   AuthLog[]
}

model AuthLog {
  id             String   @id @default(uuid())
  userId         String?
  usernameInput  String   // The email/username entered by user
  eventType      String   // LOGIN_SUCCESS, LOGIN_FAILED, LOGOUT
  failureReason  String?  // WRONG_PASSWORD, USER_NOT_FOUND, ACCOUNT_INACTIVE
  ipAddress      String
  userAgent      String   
  deviceType     String
  browser        String
  os             String
  deviceId       String?  // Fingerprint hash
  isNewDevice    Boolean  @default(false)
  isSuspicious   Boolean  @default(false)
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([usernameInput])
  @@index([ipAddress])
  @@index([createdAt])
}
