// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER") // USER or ADMIN
  avatar    String?  // Field for profile picture path
  isActive  Boolean  @default(true) // User status: Active or Not Active
  lastLogin DateTime? // Field for tracking last login time
  lastSessionId String? // To enforce one session per user
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
